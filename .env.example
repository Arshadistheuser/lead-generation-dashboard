# Database
# Local: file:./dev.db (SQLite)
# Production: postgresql://user:pass@host:5432/dbname
DATABASE_URL="file:./dev.db"

# Auth.js - generate with: npx auth secret
AUTH_SECRET="change-me"

# HubSpot Private App Token
# Scopes needed: crm.objects.contacts.read, crm.objects.companies.read, crm.objects.deals.read
HUBSPOT_ACCESS_TOKEN=""

# Vercel/Render Cron Secret
CRON_SECRET="change-me"
